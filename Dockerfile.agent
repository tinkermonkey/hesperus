# ============================================================================
# Hesperus Agent Environment
# ============================================================================
FROM switchyard-orchestrator:latest

USER root

# ============================================================================
# Install Node.js 22.x
# ============================================================================
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# ============================================================================
# Pre-install npm dependencies from manifests only
# ============================================================================
WORKDIR /workspace/hesperus

COPY package.json package-lock.json ./

RUN --mount=type=cache,target=/root/.npm \
    npm ci --legacy-peer-deps && \
    chown -R orchestrator:orchestrator node_modules

# ============================================================================
# Switch to runtime user
# ============================================================================
USER orchestrator

# ============================================================================
# Verify required CLIs
# ============================================================================
RUN node --version && \
    npm --version && \
    claude --version && \
    git --version && \
    gh --version

CMD ["/bin/bash"]
