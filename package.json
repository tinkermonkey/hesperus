{
  "name": "@tinkermonkey/hesperus-theme",
  "version": "1.0.0",
  "description": "A retro-inspired CSS-only theme for Heimdall UI with vintage CRT monitor aesthetics",
  "type": "module",
  "exports": {
    ".": "./dist/hesperus.css",
    "./tokens": "./dist/tokens.css"
  },
  "files": [
    "dist",
    "public/grid-background-light.svg",
    "public/grid-background-dark.svg",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:package": "node scripts/build-package.js",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:package"
  },
  "keywords": [
    "heimdall",
    "heimdall-ui",
    "theme",
    "design-system",
    "retro",
    "crt",
    "css"
  ],
  "author": "tinkermonkey",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinkermonkey/hesperus.git"
  },
  "bugs": {
    "url": "https://github.com/tinkermonkey/hesperus/issues"
  },
  "homepage": "https://github.com/tinkermonkey/hesperus#readme",
  "peerDependencies": {
    "@tinkermonkey/heimdall-ui": "^0.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "vite": "^7.3.1"
  }
}
